pipeline {
    agent any
    
    environment {
        // 포트 설정 (docker-compose.yml의 포트와 일치해야 함)
        HOST_PORT = '8123'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📥 코드 체크아웃...'
                checkout scm
            }
        }
        
        stage('Deploy') {
            steps {
                echo '� Docker Compose 배포 시작...'
                dir('smart_shopping_cart_back') {
                    sh '''
                        # 기존 컨테이너 내리고 이미지 새로 빌드하여 실행
                        # .env 파일은 서버의 해당 위치에 존재한다고 가정
                        docker-compose down || true
                        docker-compose up -d --build
                    '''
                }
            }
        }
        
        stage('Health Check') {
            steps {
                echo '� 헬스 체크...'
                // EC2 호스트 IP 또는 localhost를 통해 서비스 상태 확인
                // docker-compose가 8123 포트를 5000으로 매핑함
                sh '''
                    sleep 10
                    curl -f http://172.17.0.1:${HOST_PORT}/api/cart/status || exit 1
                '''
            }
        }
        
        stage('Cleanup') {
            steps {
                echo '🧹 Dangling 이미지 정리...'
                sh '''
                    docker image prune -f
                '''
            }
        }
    }
    
    post {
        success {
            echo '✅ 백엔드 배포 성공 (Docker Compose)'
        }
        failure {
            echo '❌ 백엔드 배포 실패'
        }
    }
}
